{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build ToniOS",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build"
			],
			"group": "build",
			"problemMatcher": [
				"$msCompile"
			],
			"isBackground": false,
			"options": {
				"cwd": "${workspaceFolder}/ToniOS"
			}
		},
		{
			"label": "run ToniOS",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run"
			],
			"group": "build",
			"presentation": {
				"reveal": "always"
			},
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/ToniOS"
			},
			"dependsOn": "build ToniOS"
		},
		{
			"label": "clean ToniOS",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"clean"
			],
			"group": "build",
			"presentation": {
				"reveal": "silent"
			},
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/ToniOS"
			}
		}
	]
}